# Betting Platform — Environment Configuration
# Copy this file to .env and fill in your values

# ══════════════════════════════════════════════
# Service Configuration
# ══════════════════════════════════════════════
SERVICE_NAME=gateway
ENVIRONMENT=development
PORT=8080

# ══════════════════════════════════════════════
# Database (PostgreSQL)
# ══════════════════════════════════════════════
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=betting_db
DATABASE_USER=betting_user
DATABASE_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_SSL_MODE=disable

# ══════════════════════════════════════════════
# Redis
# ══════════════════════════════════════════════
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ══════════════════════════════════════════════
# NATS
# ══════════════════════════════════════════════
NATS_URL=nats://localhost:4222

# ══════════════════════════════════════════════
# Security (CHANGE ALL DEFAULTS!)
# ══════════════════════════════════════════════
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_GENERATE_STRONG_RANDOM_32CHARS
BCRYPT_COST=12

# ══════════════════════════════════════════════
# Country/Region
# ══════════════════════════════════════════════
COUNTRY_CODE=KE
CURRENCY=KES
ALLOWED_COUNTRIES=KE,NG,GH

# ══════════════════════════════════════════════
# Betting Limits
# ══════════════════════════════════════════════
MIN_BET_STAKE=10
MAX_BET_STAKE=100000
CRASH_HOUSE_EDGE=0.01

# ══════════════════════════════════════════════
# Tax Configuration (Kenya BCLB)
# ══════════════════════════════════════════════
TAX_GGR_RATE=0.15
TAX_WHT_RATE=0.20
TAX_THRESHOLD=500

# ══════════════════════════════════════════════
# M-Pesa (Kenya) — Safaricom Daraja API
# ══════════════════════════════════════════════
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_passkey_here
MPESA_ENVIRONMENT=sandbox
MPESA_CALLBACK_URL=https://api.yourdomain.com/api/mpesa/callback

# ══════════════════════════════════════════════
# Flutterwave (Nigeria & Ghana)
# ══════════════════════════════════════════════
FLUTTERWAVE_PUBLIC_KEY=your_public_key
FLUTTERWAVE_SECRET_KEY=your_secret_key
FLUTTERWAVE_ENCRYPTION_KEY=your_encryption_key
FLUTTERWAVE_ENV=sandbox

# ══════════════════════════════════════════════
# KYC (Smile ID)
# ══════════════════════════════════════════════
SMILE_ID_API_KEY=your_api_key
SMILE_ID_PARTNER_ID=your_partner_id
SMILE_ID_ENV=sandbox
SMILE_ID_CALLBACK_URL=https://api.yourdomain.com/api/kyc/callback

# ══════════════════════════════════════════════
# Odds Provider (The Odds API)
# ══════════════════════════════════════════════
ODDS_API_KEY=your_api_key
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4

# ══════════════════════════════════════════════
# SMS (AfricasTalking)
# ══════════════════════════════════════════════
AFRICASTALKING_API_KEY=your_api_key
AFRICASTALKING_USERNAME=your_username

# ══════════════════════════════════════════════
# Logging
# ══════════════════════════════════════════════
LOG_LEVEL=info
LOG_FORMAT=json

# ══════════════════════════════════════════════
# Geolocation (MaxMind)
# ══════════════════════════════════════════════
MAXMIND_LICENSE_KEY=your_license_key
MAXMIND_DB_PATH=./data/GeoLite2-Country.mmdb
